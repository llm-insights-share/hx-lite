{
  "name": "hx-lite",
  "version": "0.4.0",
  "description": "hx-lite — simplified HarnessX: Profile → Stage → Task with Guides, Sensors and fail-closed Gates",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "hx": "./bin/hx.js",
    "hxhub": "./bin/hxhub.js"
  },
  "scripts": {
    "hx": "tsx packages/cli/src/index.ts",
    "hxhub": "tsx packages/cli/src/hxhub.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run test"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
