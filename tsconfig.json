{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "types": ["node"],
    "strict": true,
    "noUncheckedIndexedAccess": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@harnessx/core": ["packages/core/src/index.ts"],
      "@harnessx/core/*": ["packages/core/src/*"],
      "@harnessx/sensors": ["packages/sensors/src/index.ts"],
      "@harnessx/adapters": ["packages/adapters/src/index.ts"]
    }
  },
  "include": ["packages/**/*.ts", "bin/**/*.ts"]
}
